# .env Configuration File
# Configure as variáveis de ambiente da aplicação

# ===== Database =====
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mini_erp

# ===== Application =====
APP_DEBUG=false
TIMEZONE=America/Sao_Paulo

# ===== Email =====
ADMIN_EMAIL=admin@mini-erp.com.br

# ===== Webhook =====
# Token para autenticar requisições do webhook
# Gere um token seguro: php -r "echo bin2hex(random_bytes(32));"
WEBHOOK_TOKEN=seu_token_secreto_aqui_replace_isso
